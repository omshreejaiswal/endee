# ======================================================================
# AI Travel Planner - Environment Variables Configuration
# ======================================================================
# Copy this file to .env and fill in the required values
# cp .env.example .env
#
# Never commit .env to version control!
# ======================================================================

# ======================================================================
# Groq API Configuration
# ======================================================================
# Get your free API key from: https://console.groq.com/
# Required for AI response generation (optional if using demo mode)
# Model: llama3-8b-8192 (Fast and efficient)
#
# To obtain:
# 1. Visit https://console.groq.com/
# 2. Sign up for free account
# 3. Navigate to API Keys section
# 4. Create new API key
# 5. Copy and paste below
#
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# ======================================================================
# Endee Vector Database Configuration
# ======================================================================
# Endee is the high-performance vector database for semantic search
# Repository: https://github.com/endee-io/endee
#
# ENDEE_HOST: URL of the Endee server (default: http://localhost:19530)
#   - Local development: http://localhost:19530
#   - Docker container: http://endee:19530
#   - Remote server: http://your-endee-server.com:19530
#
ENDEE_HOST=http://localhost:19530

# ENDEE_USE_FALLBACK: Use in-memory storage if Endee unavailable
#   - true: Enable fallback (recommended for robustness)
#   - false: Fail if Endee unavailable
#
ENDEE_USE_FALLBACK=true

# ======================================================================
# Application Configuration
# ======================================================================

# DEBUG: Enable debug mode
#   - true: Show detailed error messages and logs
#   - false: Production mode (quiet)
#
DEBUG=false

# LOG_LEVEL: Python logging level
#   - DEBUG: Verbose output including all operations
#   - INFO: Standard logging (recommended)
#   - WARNING: Only warnings and errors
#   - ERROR: Only error messages
#
LOG_LEVEL=INFO

# ======================================================================
# Production Recommendations
# ======================================================================
# 1. Always set a strong GROQ_API_KEY
# 2. Use managed Endee service in production (not local)
# 3. Enable HTTPS/TLS for all connections
# 4. Set DEBUG=false in production
# 5. Use environment-specific .env files
# 6. Never commit secrets to version control
# 7. Use secrets management (AWS Secrets Manager, Google Cloud Secret Manager, etc.)
